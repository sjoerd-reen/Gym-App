rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    function isValidNumber(field) {
      return request.resource.data[field] is number;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.auth.uid == userId &&
                    request.resource.data.keys().hasOnly(['name', 'createdAt']) &&
                    request.resource.data.name in ['Sjoerd', 'Nikita'];
      allow update: if isAuthenticated() && 
                    request.auth.uid == userId &&
                    request.resource.data.keys().hasOnly(['name', 'createdAt']) &&
                    request.resource.data.name in ['Sjoerd', 'Nikita'] &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    // Workouts
    match /workouts/{workoutId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated(); // For prototype, allow authenticated users to manage workouts
    }

    // Exercises
    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated(); // For prototype, allow authenticated users to manage exercises
    }

    // Workout Logs
    match /workoutLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['userId', 'workoutId', 'date', 'completed']);
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['userId', 'workoutId', 'date', 'completed']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Exercise Logs
    match /exerciseLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['workoutLogId', 'exerciseId', 'sets']);
      allow update: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['workoutLogId', 'exerciseId', 'sets']);
      allow delete: if isAuthenticated();
    }
    // Exercise Images
    match /exercise_images/{imageId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
  }
}
